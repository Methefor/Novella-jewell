# Bu dosya git'e girer — GERÇEK DEĞER YAZMA, sadece şablon.
# Kopyala: cp .env.example .env.local

# Site adresi.
# Vercel'de gerçek adresi gir VEYA hiç tanımlama (kod vercel.app'e düşer).
# ⚠️ localhost bırakılırsa canonical/OG/sitemap bozulur.
NEXT_PUBLIC_SITE_URL=https://novella-jewell.vercel.app

# Shopier — ⚠️ NEXT_PUBLIC_ öneki KULLANMA (secret tarayıcıya sızar).
SHOPIER_API_KEY=
SHOPIER_API_SECRET=
SHOPIER_WEBSITE_INDEX=1

# Google Analytics — boş bırakılırsa GA yüklenmez.
NEXT_PUBLIC_GA_ID=
