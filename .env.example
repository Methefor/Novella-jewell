# ════════════════════════════════════════════════════════════════
#  NOVELLA — Ortam Değişkenleri (şablon)
#  Bu dosya git'e girer. GERÇEK DEĞER YAZMA.
#  Kopyala:  cp .env.example .env.local   (.env.local git'e girmez)
#  Aynı değerleri Vercel > Settings > Environment Variables'a da gir.
# ════════════════════════════════════════════════════════════════

# ── Site adresi ──────────────────────────────────────────────────
# Canonical, OG görseli, sitemap ve JSON-LD hepsi buradan okur.
# Vercel'de gerçek adresi gir VEYA hiç tanımlama (kod otomatik
# https://novella-jewell.vercel.app'e düşer).
# ⚠️ localhost bırakılırsa canlıda tüm SEO adresleri bozulur.
NEXT_PUBLIC_SITE_URL=https://novella-jewell.vercel.app


# ── PayTR ÖDEME (zorunlu — bunlar olmadan ödeme alınmaz) ──────────
# Shopier kendi sitede satış desteğini kaldırdığı için (2026-07)
# proje PayTR iFrame API'ye geçti.
#
# NEREDEN ALINIR (PayTR Mağaza Paneli):
#    Destek & Kurulum > Entegrasyon Bilgileri (sadece ana/teknik kullanıcı görür)
#    Mağaza no        → PAYTR_MERCHANT_ID
#    Merchant key     → PAYTR_MERCHANT_KEY
#    Merchant salt    → PAYTR_MERCHANT_SALT
#
# ⚠️ NEXT_PUBLIC_ ÖNEKİ KOYMA — o önek değeri tarayıcıya gömer ve
#    secret'ı herkese açar. Bunlar yalnızca sunucuda okunur.
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=

# Test modu: 1 (test işlemler), 0 (canlı). Canlıya geçmeden önce 0 yap.
# PayTR panelinde mağaza canlı modda iken 1 gönderilirse test işlem yapılır.
PAYTR_TEST_MODE=1

# Ödeme sağlayıcısı. Boş bırakıldığında paytr çalışır; eski shopier
# kodu referans olarak duruyor ancak yeni kurulumda kullanılmamalı.
CHECKOUT_PROVIDER=paytr


# ── Veritabanı — Neon Postgres (zorunlu) ─────────────────────────
# Sipariş kayıtları burada tutulur. Vercel Storage (Neon) bağlanınca
# otomatik sağlanır. Lokal için:  vercel env pull .env.local
# ⚠️ Bu yoksa /api/checkout 503 döner (kaydedilemeyen sipariş alınmaz).
DATABASE_URL=

# ── Resend — sipariş onay e-postası (opsiyonel) ──────────────────
# resend.com'dan API anahtarı. Boşsa e-posta atlanır, sipariş akışı
# kırılmaz. Gönderici adresi lib/config.ts > EMAIL.from'da sabit.
# ⚠️ Domain doğrulaması yokken Resend test göndericisi yalnızca hesap
#    SAHİBİNİN e-postasına teslim eder; gerçek müşterilere gitmez.
RESEND_API_KEY=

# ── Google Analytics (opsiyonel) ─────────────────────────────────
# Boş bırakılırsa GA hiç yüklenmez. Reklam/pazarlama fazında gir;
# dönüşüm olayları (ürün görüntüleme → sepet → ödeme → satın alma)
# zaten kodda hazır, ID girilip çerez onayı verilince akmaya başlar.
NEXT_PUBLIC_GA_ID=


# ════════════════════════════════════════════════════════════════
#  Lokal kurulum + migration
# ════════════════════════════════════════════════════════════════
# 1. Vercel'deki değişkenleri .env.local'e çek:
#    npx vercel env pull .env.local
#
# 2. İlk (veya yeni) migration'ı veritabanına uygula — db:push KULLANMA,
#    çünkü push sequence gibi elle eklenen yapıları atlayabilir:
#    npm run db:migrate
#
# 3. Şemanın veritabanıyla uyumlu olduğunu doğrula:
#    npx drizzle-kit check


# ════════════════════════════════════════════════════════════════
#  Vercel env temizliği (eski dark/gold site kalıntıları)
# ════════════════════════════════════════════════════════════════
# Aşağıdaki değişkenler mevcut kod tarafından OKUNMUYOR; Vercel
# Environment Variables sayfasından silinebilir. Özellikle
# NEXT_PUBLIC_SHOPIER_API_KEY gibi NEXT_PUBLIC_ ile başlayan
# secret'lar tarayıcıya sızmıştır, en kısa sürede kaldırılmalı:
#
#   SANITY_*, NEXTAUTH_*, ADMIN_EMAIL, ADMIN_PASSWORD,
#   NEXT_PUBLIC_SHOPIER_API_KEY, NEXT_PUBLIC_SHOPIER_STORE_URL,
#   NEXT_PUBLIC_INSTAGRAM_URL, NEXT_PUBLIC_WHATSAPP_NUMBER,
#   DATABASE_PG*, DATABASE_POSTGRES_*, DATABASE_NEON_*,
#   DATABASE_URL_UNPOOLED, DATABASE_VITE_*, VERCEL_OIDC_TOKEN
#
# Kod tarafından kullanılan tek veritabanı değişkeni: DATABASE_URL
