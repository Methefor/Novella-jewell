# ════════════════════════════════════════════════════════════════
#  NOVELLA — Ortam Değişkenleri (şablon)
#  Bu dosya git'e girer. GERÇEK DEĞER YAZMA.
#  Kopyala:  cp .env.example .env.local   (.env.local git'e girmez)
#  Aynı değerleri Vercel > Settings > Environment Variables'a da gir.
# ════════════════════════════════════════════════════════════════

# ── Site adresi ──────────────────────────────────────────────────
# Canonical, OG görseli, sitemap ve JSON-LD hepsi buradan okur.
# Vercel'de gerçek adresi gir VEYA hiç tanımlama (kod otomatik
# https://novella-jewell.vercel.app'e düşer).
# ⚠️ localhost bırakılırsa canlıda tüm SEO adresleri bozulur.
NEXT_PUBLIC_SITE_URL=https://novella-jewell.vercel.app


# ── Shopier ÖDEME (zorunlu — bunlar olmadan ödeme alınmaz) ────────
# ⚠️ Bunlar PAT (Kişisel Erişim Anahtarı) DEĞİL. Ödeme akışı ayrı bir
#    kimlik kullanır: "API kullanıcısı / API şifresi" (key + secret).
#
# NEREDEN ALINIR (Shopier paneli):
#    Entegrasyonlar > Modül Yönetimi > Modül Ayarları
#    (Bazı panellerde: "Ödeme & API Yönetimi" altında.)
#    Oradaki "API Anahtarı" → SHOPIER_API_KEY
#            "API Şifresi"  → SHOPIER_API_SECRET
#
# ⚠️ NEXT_PUBLIC_ ÖNEKİ KOYMA — o önek değeri tarayıcıya gömer ve
#    secret'ı herkese açar. Bunlar yalnızca sunucuda okunur.
SHOPIER_API_KEY=
SHOPIER_API_SECRET=

# Mağaza site indeksi. Tek mağazan varsa 1 kalır.
SHOPIER_WEBSITE_INDEX=1

# Ödeme sağlayıcısı. Boş bırak (varsayılan: shopier). iyzico/paytr'e
# geçilirse yeni sınıf yazılıp bu değişken değiştirilir.
# CHECKOUT_PROVIDER=shopier


# ── Shopier PAT (OPSİYONEL — ödeme için DEĞİL) ───────────────────
# Kişisel Erişim Anahtarı, sipariş/ürün/webhook yöneten REST API içindir
# (https://api.shopier.com/v1, Authorization: Bearer <PAT>). Şu anki kod
# bunu KULLANMIYOR. İleride sipariş durumunu Shopier'den otomatik çekmek
# veya webhook kurmak istersen buraya eklenir.
# NEREDEN: Hesap Yönetimi > Kişisel Erişim Anahtarı (2FA gerekir).
# SHOPIER_PAT=


# ── Google Analytics (opsiyonel) ─────────────────────────────────
# Boş bırakılırsa GA hiç yüklenmez. Reklam/pazarlama fazında gir;
# dönüşüm olayları (ürün görüntüleme → sepet → ödeme → satın alma)
# zaten kodda hazır, ID girilip çerez onayı verilince akmaya başlar.
NEXT_PUBLIC_GA_ID=
