# Site URL - Vercel'de Environment Variables'a ekle
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shopier API - Vercel Dashboard > Settings > Environment Variables'a gerçek değerleri ekle
NEXT_PUBLIC_SHOPIER_API_KEY=your_shopier_api_key_here
NEXT_PUBLIC_SHOPIER_API_SECRET=your_shopier_api_secret_here

# Google Analytics (opsiyonel)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
